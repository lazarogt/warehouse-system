{
  "name": "warehouse-system-desktop",
  "private": true,
  "version": "0.1.0",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:watch": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on http-get://localhost:5173 file:./dist/main.js file:./dist/preload.js && cross-env ELECTRON_RENDERER_URL=http://localhost:5173 nodemon --signal SIGTERM --delay 250ms --watch dist --ext js --exec \"electron .\"",
    "start": "electron .",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.1",
    "cross-env": "^7.0.3",
    "electron": "^35.5.1",
    "nodemon": "^3.1.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.3"
  }
}
