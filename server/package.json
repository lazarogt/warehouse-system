    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.1",
    "@types/pdfkit": "^0.17.5",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.0.0",
